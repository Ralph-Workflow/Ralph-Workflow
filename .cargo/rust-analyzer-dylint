#!/usr/bin/env python3

import os
import subprocess
import sys


def run_check(command: list[str], env: dict[str, str]) -> int:
    process = subprocess.Popen(
        command,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )

    assert process.stdout is not None
    for line in process.stdout:
        if line.startswith('{'):
            sys.stdout.write(line)
        else:
            sys.stderr.write(line)

    return process.wait()


def main() -> int:
    env = dict(os.environ)
    env.setdefault("CARGO_TERM_QUIET", "true")
    env.setdefault("CARGO_TERM_PROGRESS_WHEN", "never")

    # Dylint env inherits base env but adds RUSTFLAGS to match `cargo xtask verify`
    # (--cap-lints=deny caps forbid→deny; -D warnings promotes all warns to errors).
    dylint_env = dict(env)
    dylint_env["RUSTFLAGS"] = "--cap-lints=deny -D warnings"

    clippy_command = [
        "cargo",
        "clippy",
        "-q",
        "--workspace",
        "--message-format=json",
        "--all-targets",
        "--keep-going",
    ]
    # Consistent with `cargo xtask verify` dylint lane:
    #   - --lib ralph_lints: use only the workspace lint library (excludes ralph_lints package itself)
    #   - --workspace: check all workspace packages
    #   - --keep-going: don't stop on first package failure
    # Note: unlike xtask, we keep --all-targets for full IDE coverage; ralph-workflow
    # binary-target warning escalation is acceptable in interactive use.
    dylint_command = [
        "cargo",
        "dylint",
        "-q",
        "--lib",
        "ralph_lints",
        "--workspace",
        "--keep-going",
        "--",
        "--message-format=json",
        "--all-targets",
    ]
    xtask_command = [
        "cargo",
        "xtask",
        "lsp-forbidden-allow-expect",
    ]

    clippy_exit_code = run_check(clippy_command, env)
    dylint_exit_code = run_check(dylint_command, dylint_env)
    xtask_exit_code = run_check(xtask_command, env)
    return clippy_exit_code or dylint_exit_code or xtask_exit_code


if __name__ == "__main__":
    raise SystemExit(main())
