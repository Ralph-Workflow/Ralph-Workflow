{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Primary agent with full access. Delegates work to specialized subagents (workflow-gui, workflow-core, workflow-reducer, etc.) for parallel execution and focused expertise. Coordinate subagents rather than doing all work directly.",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "permission": {
        "bash": {
          "cargo *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git status *": "allow",
          "head *": "allow",
          "make *": "allow",
          "tail *": "allow"
        },
        "read": "allow",
        "write": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "skill": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "task": "allow"
      }
    },
