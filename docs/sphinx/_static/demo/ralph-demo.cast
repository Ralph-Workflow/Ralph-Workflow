[0.503931, "o", "$ ralph --help\r\n"]
[1.564083, "o", "                                                                                \r\n Usage: ralph [OPTIONS] COMMAND [ARGS]...                                       \r\n                                                                                \r\n"]
[1.566849, "o", " Ralph Workflow - Multi-agent AI orchestration pipeline.                        \r\n                                                                                \r\n Ralph Workflow orchestrates AI coding agents to implement changes based on     \r\n PROMPT.md.                                                                     \r\n It runs a developer agent for code implementation across multiple planning and \r\n development iterations, automatically staging and committing the final result. \r\n                                                                                \r\n"]
[1.608142, "o", "\u256d\u2500 Options \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\r\n\u2502 --prompt                -P      TEXT                   Inline prompt text    \u2502\r\n\u2502                                                        for quick runs (use   \u2502\r\n\u2502                                                        with --quick/-Q)      \u2502\r\n\u2502 --config                -c      TEXT                   Path to configuration \u2502\r\n\u2502                                                        file                  \u2502\r\n\u2502 --developer-iters       -D      INTEGER RANGE [x>=1]   Maximum developer     \u2502\r\n\u2502                                                        agent iterations per  \u2502\r\n\u2502                                                        run.                  \u2502\r\n\u2502 --quick                 -Q                             Quick mode: run a     \u2502\r\n\u2502                                                        single developer      \u2502\r\n\u2502                                                        iteration (equivalent \u2502\r\n\u2502                                                        to -D 1).             \u2502\r\n\u2502 --thorough              -T                             Thorough mode: run    \u2502\r\n\u2502                                                        ten developer         \u2502\r\n\u2502                                                        iterations            \u2502\r\n\u2502                                                        (equivalent to -D     \u2502\r\n\u2502                                                        10).                  \u2502\r\n"]
[1.608231, "o", "\u2502 --counter                       TEXT                   Override a            \u2502\r\n\u2502                                                        policy-declared       \u2502\r\n"]
