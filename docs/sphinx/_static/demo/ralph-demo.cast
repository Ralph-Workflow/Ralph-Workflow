[0.002708, "o", "\r\n  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\r\n  \u2551   Ralph Workflow v0.8.8         \u2551\r\n  \u2551   Multi-Agent AI Orchestration  \u2551\r\n"]
