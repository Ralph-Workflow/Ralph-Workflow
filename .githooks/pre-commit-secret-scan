#!/usr/bin/env bash
# pre-commit-secret-scan — Block commits containing secrets/tokens
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    exit 0
fi

# Patterns that should NEVER appear in committed content
SECRET_PATTERNS=(
    'ghp_[A-Za-z0-9]{36,}'                  # GitHub PAT (classic)
    'github_pat_[A-Za-z0-9_]{80,}'           # GitHub PAT (fine-grained)
    'gho_[A-Za-z0-9_]{36,}'                  # GitHub OAuth
    'ghu_[A-Za-z0-9_]{36,}'                  # GitHub user token
    'ghs_[A-Za-z0-9_]{36,}'                  # GitHub SSH key
    'ghr_[A-Za-z0-9_]{36,}'                  # GitHub refresh token
    'sk-[A-Za-z0-9]{20,}'                    # OpenAI API key
    'sk-ant-[A-Za-z0-9]{20,}'                # Anthropic API key
    'AKIA[0-9A-Z]{16}'                       # AWS access key
    'xox[abposr]-[A-Za-z0-9-]{24,}'         # Slack tokens
    'pypi-[A-Za-z0-9]{20,}'                  # PyPI tokens
    'gh[aioz]_[A-Za-z0-9_]{40,}'             # Catch-all other GitHub token formats
)

FOUND=0

while IFS= read -r file; do
    case "$file" in
        *.md|*.txt|*.py|*.sh|*.json|*.toml|*.yaml|*.yml) ;;
        *) continue ;;
    esac

    case "$file" in
        vendor/*|node_modules/*|__pycache__/*) continue ;;
    esac

    staged_content=$(git show ":${file}" 2>/dev/null || true)
    [ -z "$staged_content" ] && continue

    for pattern in "${SECRET_PATTERNS[@]}"; do
        if echo "$staged_content" | grep -Eq "$pattern"; then
            matched_lines=$(echo "$staged_content" | grep -En "$pattern" || true)
            while IFS= read -r line; do
                linenum=$(echo "$line" | cut -d: -f1)
                redacted=$(echo "$line" | sed -E 's/(ghp_|github_pat_|gho_|ghu_|ghs_|ghr_|sk-|sk-ant-|AKIA|xox[a-z]+-|pypi-|gh[aioz]_)[A-Za-z0-9_-]+/\1********REDACTED**********/g')
                echo -e "  ${file}:${linenum}: ${redacted}" >&2
            done <<< "$matched_lines"
            FOUND=$((FOUND + 1))
        fi
    done
done <<< "$FILES"

if [ "$FOUND" -gt 0 ]; then
    echo ""
    echo -e "${RED}SECURITY BLOCK: $FOUND secret(s) detected in staged changes.${NC}" >&2
    echo -e "${YELLOW}Remove them or add the file path to .gitignore and commit again.${NC}" >&2
    echo -e "${YELLOW}Never hardcode credentials in committed files. Use env vars or .env files.${NC}" >&2
    exit 1
fi

exit 0
