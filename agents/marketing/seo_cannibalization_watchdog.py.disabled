#!/usr/bin/env python3
"""SEO Cannibalization Watchdog — prevents GitHub mirror from outranking Codeberg.

Problem: GitHub has higher domain authority than Codeberg. If both repos have
identical README content, Google ranks the GitHub mirror above Codeberg for brand
searches, sending organic traffic to the mirror instead of the primary repo.

Fix (audit #33): GitHub README is overwritten with a short mirror notice after
each sync. This watchdog verifies the fix stays in place.

Run: weekly via cron (Sun 07:15 CEST).
"""

from __future__ import annotations

import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

WORKSPACE = Path("/home/mistlight/.openclaw/workspace")
SYNC_SCRIPT = WORKSPACE / "agents" / "marketing" / "sync_to_github.sh"
GITHUB_README_URL = "https://raw.githubusercontent.com/Ralph-Workflow/Ralph-Workflow/main/README.md"
SYNC_LOG = WORKSPACE / "agents" / "marketing" / "logs" / "sync_github.log"
WATCHDOG_LOG = WORKSPACE / "agents" / "marketing" / "logs" / "seo_cannibalization_latest.json"
WATCHDOG_HISTORY = WORKSPACE / "agents" / "marketing" / "logs" / "seo_cannibalization_history.jsonl"

# If GitHub README exceeds this length, it's the full README, not the mirror notice.
# Mirror notice should be < 1000 chars. Full README is ~9700+ chars.
MIRROR_NOTICE_MAX_BYTES = 1500
FULL_README_MIN_BYTES = 5000

# Expected mirror-notice markers (must appear in the stripped version)
MIRROR_MARKERS = [
    "mirror",
    "Codeberg",
    "primary",
]


def fetch_github_readme() -> tuple[int, str]:
    """Fetch the raw GitHub README via curl (no auth needed for public repos)."""
    try:
        proc = subprocess.run(
            ["curl", "-sS", "--max-time", "15", "-w", "%{http_code}", "-o", "/tmp/gh_readme_check.md",
             GITHUB_README_URL],
            capture_output=True, text=True, timeout=20
        )
        http_code = proc.stdout.strip()
        content = Path("/tmp/gh_readme_check.md").read_text(encoding="utf-8", errors="replace")
        return int(http_code), content
    except Exception as e:
        return 0, f"FETCH_ERROR: {e}"


def check_sync_script_post_hook() -> dict:
    """Check if sync_to_github.sh includes the README mirror-notice post-sync hook."""
    if not SYNC_SCRIPT.exists():
        return {"has_post_hook": False, "reason": "sync_script_missing"}
    
    content = SYNC_SCRIPT.read_text(encoding="utf-8")
    
    # Check for mirror-notice logic
    has_mirror_readme_replace = "MIRROR_README" in content and ("cp" in content or "cat" in content)
    has_readme_overwrite = "README.md" in content and ("github" in content.lower())
    
    # Check if it currently preserves (bad) or strips (good) the README
    preserves_full = "Preserve full README" in content or "README kept identical" in content
    strips_to_notice = "mirror notice" in content.lower() or "MIRROR_README" in content
    
    return {
        "has_post_hook": has_readme_overwrite,
        "has_mirror_notice_logic": has_mirror_readme_replace or strips_to_notice,
        "preserves_full_readme": preserves_full,
        "strips_to_mirror_notice": strips_to_notice,
        "status": "healthy" if strips_to_notice else ("cannibalizing" if preserves_full else "unknown"),
    }


def check_last_sync() -> dict:
    """Check when the last sync ran and its status."""
    if not SYNC_LOG.exists():
        return {"last_sync": None, "status": "no_sync_log"}
    
    lines = SYNC_LOG.read_text(encoding="utf-8").strip().split("\n")
    if not lines:
        return {"last_sync": None, "status": "empty_log"}
    
    last_line = lines[-1]
    return {
        "last_sync_line": last_line,
        "preserves_readme": "README kept identical" in last_line,
        "status": "preserves_full_readme" if "README kept identical" in last_line else "unknown",
    }


def main() -> int:
    now = datetime.now(timezone.utc)
    findings = []
    severity = "ok"

    # 1. Check sync script configuration
    sync_check = check_sync_script_post_hook()
    if sync_check.get("preserves_full_readme"):
        findings.append("CRITICAL: sync_to_github.sh preserves full README on GitHub — Codeberg SEO is being cannibalized")
        severity = "critical"
    elif sync_check.get("strips_to_mirror_notice"):
        findings.append("OK: sync_to_github.sh includes mirror-notice logic")
    else:
        findings.append("WARNING: sync_to_github.sh configuration is unknown")
        severity = "warning"

    # 2. Check last sync log
    sync_status = check_last_sync()
    if sync_status.get("preserves_readme"):
        findings.append("Last sync preserved full README — regression confirmed")

    # 3. Check live GitHub README size
    http_code, content = fetch_github_readme()
    if http_code == 200:
        content_len = len(content)
        if content_len > FULL_README_MIN_BYTES:
            findings.append(f"GitHub README is {content_len} bytes (full README) — actively cannibalizing Codeberg SEO")
            severity = "critical"
        elif content_len < MIRROR_NOTICE_MAX_BYTES:
            findings.append(f"GitHub README is {content_len} bytes (mirror notice) — safe")
            severity = "ok" if severity == "ok" else severity
        else:
            findings.append(f"GitHub README is {content_len} bytes (ambiguous size)")
            severity = "warning" if severity == "ok" else severity
    else:
        findings.append(f"Could not fetch GitHub README (HTTP {http_code})")
        if severity == "ok":
            severity = "warning"

    payload = {
        "timestamp": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
        "severity": severity,
        "findings": findings,
        "sync_script_check": sync_check,
        "sync_log_check": sync_status,
        "github_readme_http": http_code,
        "github_readme_bytes": len(content) if http_code == 200 else None,
        "action_required": severity == "critical",
        "fix_instruction": (
            "Restore mirror-notice post-sync hook in sync_to_github.sh. "
            "The hook should overwrite GitHub README with a short mirror notice "
            "after each push to prevent Google from ranking GitHub above Codeberg."
        ) if severity == "critical" else None,
    }

    WATCHDOG_LOG.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
    with WATCHDOG_HISTORY.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(payload) + "\n")

    if severity == "critical":
        print(f"[SEO CANNIBALIZATION CRITICAL] {'; '.join(findings)}")
        return 1
    elif severity == "warning":
        print(f"[SEO CANNIBALIZATION WARNING] {'; '.join(findings)}")
        return 0
    else:
        print(f"[SEO CANNIBALIZATION OK] {'; '.join(findings)}")
        return 0


if __name__ == "__main__":
    sys.exit(main())
