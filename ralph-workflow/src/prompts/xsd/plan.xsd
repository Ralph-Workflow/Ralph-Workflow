<?xml version="1.0" encoding="UTF-8"?>
<!--
  Plan XSD Schema v3.0 - Flat, executor-friendly design

  Equivalent to plan.schema.json. Max 3 nesting levels.
  All text content is xs:string (markdown allowed, no rich content types).
  No ralph- prefixes. Enum values use underscores (file_change, not file-change).
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- ======================================================================= -->
  <!-- ENUMERATIONS                                                            -->
  <!-- ======================================================================= -->

  <!-- File action: create, modify, delete -->
  <xs:simpleType name="FileActionType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="create"/>
      <xs:enumeration value="modify"/>
      <xs:enumeration value="delete"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Step type: file_change, action, research -->
  <xs:simpleType name="StepTypeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="file_change"/>
      <xs:enumeration value="action"/>
      <xs:enumeration value="research"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Priority: critical, high, medium, low -->
  <xs:simpleType name="PriorityType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="critical"/>
      <xs:enumeration value="high"/>
      <xs:enumeration value="medium"/>
      <xs:enumeration value="low"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Severity: low, medium, high, critical -->
  <xs:simpleType name="SeverityType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="low"/>
      <xs:enumeration value="medium"/>
      <xs:enumeration value="high"/>
      <xs:enumeration value="critical"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ======================================================================= -->
  <!-- SUMMARY                                                                 -->
  <!-- ======================================================================= -->

  <!-- Scope item: text (required), count and category (optional) -->
  <xs:complexType name="ScopeItemType">
    <xs:sequence>
      <xs:element name="text" type="xs:string"/>
      <xs:element name="count" type="xs:string" minOccurs="0"/>
      <xs:element name="category" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Summary: context (required) + scope_items (min 3) -->
  <xs:complexType name="SummaryType">
    <xs:sequence>
      <xs:element name="context" type="xs:string"/>
      <xs:element name="scope_items">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="scope_item" type="ScopeItemType" minOccurs="3" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- SKILLS AND MCP                                                          -->
  <!-- ======================================================================= -->

  <!-- Simple string arrays for skills and mcps -->
  <xs:complexType name="SkillsMcpType">
    <xs:sequence>
      <xs:element name="skills">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="skill" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="mcps">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="mcp" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- PARALLEL PLAN (RFC-009 Phase 4)                                         -->
  <!-- ======================================================================= -->

  <!-- Edit area: paths and directories arrays -->
  <xs:complexType name="EditAreaType">
    <xs:sequence>
      <xs:element name="paths">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="path" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="directories">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="directory" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Work unit: id, description, edit_area required; depends_on optional -->
  <xs:complexType name="WorkUnitType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="description" type="xs:string"/>
      <xs:element name="edit_area" type="EditAreaType"/>
      <xs:element name="depends_on" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="dep" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- STEPS                                                                   -->
  <!-- ======================================================================= -->

  <!-- Target file: path + action -->
  <xs:complexType name="TargetType">
    <xs:sequence>
      <xs:element name="path" type="xs:string"/>
      <xs:element name="action" type="FileActionType"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Step: number, title, content required; step_type, priority, targets, location, rationale, depends_on optional -->
  <xs:complexType name="StepType">
    <xs:sequence>
      <xs:element name="number" type="xs:positiveInteger"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="step_type" type="StepTypeEnum" minOccurs="0" default="file_change"/>
      <xs:element name="priority" type="PriorityType" minOccurs="0"/>
      <xs:element name="targets" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="target" type="TargetType" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="location" type="xs:string" minOccurs="0"/>
      <xs:element name="rationale" type="xs:string" minOccurs="0"/>
      <xs:element name="content" type="xs:string"/>
      <xs:element name="depends_on" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="dep" type="xs:positiveInteger" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- CRITICAL FILES                                                          -->
  <!-- ======================================================================= -->

  <!-- Primary file: path + action required, estimated_changes optional -->
  <xs:complexType name="PrimaryFileType">
    <xs:sequence>
      <xs:element name="path" type="xs:string"/>
      <xs:element name="action" type="FileActionType"/>
      <xs:element name="estimated_changes" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Reference file: path + purpose required -->
  <xs:complexType name="ReferenceFileType">
    <xs:sequence>
      <xs:element name="path" type="xs:string"/>
      <xs:element name="purpose" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Critical files: primary_files required (min 1), reference_files optional -->
  <xs:complexType name="CriticalFilesType">
    <xs:sequence>
      <xs:element name="primary_files">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="file" type="PrimaryFileType" minOccurs="1" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="reference_files" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="file" type="ReferenceFileType" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- RISKS AND VERIFICATION                                                  -->
  <!-- ======================================================================= -->

  <!-- Risk-mitigation pair: risk + mitigation required, severity optional -->
  <xs:complexType name="RiskPairType">
    <xs:sequence>
      <xs:element name="severity" type="SeverityType" minOccurs="0"/>
      <xs:element name="risk" type="xs:string"/>
      <xs:element name="mitigation" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Verification item: method + expected_outcome required -->
  <xs:complexType name="VerificationType">
    <xs:sequence>
      <xs:element name="method" type="xs:string"/>
      <xs:element name="expected_outcome" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ======================================================================= -->
  <!-- ROOT ELEMENT: plan                                                      -->
  <!-- ======================================================================= -->

  <xs:element name="plan">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="summary" type="SummaryType"/>
        <xs:element name="skills_mcp" type="SkillsMcpType" minOccurs="0"/>
        <xs:element name="parallel_plan" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="work_unit" type="WorkUnitType" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="steps">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="step" type="StepType" minOccurs="1" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="critical_files" type="CriticalFilesType"/>
        <xs:element name="risks_mitigations">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="risk_pair" type="RiskPairType" minOccurs="1" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="verification_strategy">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="verification" type="VerificationType" minOccurs="1" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema>
