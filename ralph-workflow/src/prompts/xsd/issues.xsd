<?xml version="1.0" encoding="UTF-8"?>
<!--
  Issues XSD Schema (revised to match issues.schema.json)

  Discriminated union: either issues_found with a list of issues,
  or no_issues_found with an explanation.
  No mixed content; all text fields are xs:string.
  No ralph- prefixes.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- A single issue with optional skill and MCP recommendations -->
  <xs:complexType name="IssueType">
    <xs:sequence>
      <xs:element name="text" type="xs:string"/>
      <xs:element name="skills" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="skill" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="mcps" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="mcp" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:element name="issues">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="type">
          <xs:simpleType>
            <xs:restriction base="xs:string">
              <xs:enumeration value="issues_found"/>
              <xs:enumeration value="no_issues_found"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:choice>
          <!-- issues_found variant: one or more issue elements -->
          <xs:element name="issue" type="IssueType" maxOccurs="unbounded"/>
          <!-- no_issues_found variant: explanation string -->
          <xs:element name="explanation" type="xs:string"/>
        </xs:choice>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
