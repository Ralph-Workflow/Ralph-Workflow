<?xml version="1.0" encoding="UTF-8"?>
<!--
  Commit Message XSD Schema (revised to match commit_message.schema.json)

  Discriminated union: either a commit with subject and optional body/files,
  or a skip with a reason.
  No mixed content; all text fields are xs:string.
  No ralph- prefixes.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- Reason for excluding a file -->
  <xs:simpleType name="ExcludedFileReasonType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="internal_ignore"/>
      <xs:enumeration value="not_task_related"/>
      <xs:enumeration value="sensitive"/>
      <xs:enumeration value="deferred"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- A single excluded file entry -->
  <xs:complexType name="ExcludedFileEntryType">
    <xs:sequence>
      <xs:element name="path" type="xs:string"/>
      <xs:element name="reason" type="ExcludedFileReasonType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:element name="commit-message">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="type">
          <xs:simpleType>
            <xs:restriction base="xs:string">
              <xs:enumeration value="commit"/>
              <xs:enumeration value="skip"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:choice>
          <!-- commit variant -->
          <xs:sequence>
            <xs:element name="subject" type="xs:string"/>
            <xs:element name="body" type="xs:string" minOccurs="0"/>
            <xs:element name="body-summary" type="xs:string" minOccurs="0"/>
            <xs:element name="body-details" type="xs:string" minOccurs="0"/>
            <xs:element name="body-footer" type="xs:string" minOccurs="0"/>
            <xs:element name="files" minOccurs="0">
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="file" type="xs:string" minOccurs="1" maxOccurs="unbounded"/>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
            <xs:element name="excluded-files" minOccurs="0">
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="excluded-file" type="ExcludedFileEntryType"
                              minOccurs="1" maxOccurs="unbounded"/>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
          <!-- skip variant -->
          <xs:element name="reason" type="xs:string"/>
        </xs:choice>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
