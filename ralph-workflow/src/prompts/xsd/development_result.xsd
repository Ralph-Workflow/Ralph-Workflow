<?xml version="1.0" encoding="UTF-8"?>
<!--
  Development Result XSD Schema (revised for JSON Schema alignment)

  Covers both normal and continuation submissions.
  All text fields are plain xs:string (no mixed content).
  No ralph- prefixes on child elements.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <xs:element name="development-result">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="status">
          <xs:simpleType>
            <xs:restriction base="xs:string">
              <xs:enumeration value="completed"/>
              <xs:enumeration value="partial"/>
              <xs:enumeration value="failed"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
        <xs:element name="summary" type="xs:string"/>
        <xs:element name="files-changed" type="xs:string" minOccurs="0"/>
        <xs:element name="next-steps" type="xs:string" minOccurs="0"/>
        <xs:element name="skills-mcp" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="skill" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
              <xs:element name="mcp" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="continuation" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="prior-session-id" type="xs:string"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema>
