    "ScopeItem": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "anyOf": [
            {
              "enum": [
                "bugfix",
                "feature",
                "refactor",
                "test",
                "docs",
                "infra",
                "migration",
                "security",
                "performance",
                "cleanup",
                "research",
                "unknown",
                "file_change",
                "prompt",
                "other"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category"
        },
        "count": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Count"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ScopeItem",
      "type": "object"
    },
    "SkillsMcp": {
      "additionalProperties": false,
      "properties": {
        "mcps": {
          "items": {
            "type": "string"
          },
          "title": "Mcps",
          "type": "array"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Skills",
          "type": "array"
        }
      },
      "required": [
        "skills"
      ],
      "title": "SkillsMcp",
      "type": "object"
