{
  "$defs": {
    "AcceptanceCriteria": {
      "additionalProperties": false,
      "properties": {
        "criteria": {
          "items": {
            "$ref": "#/$defs/AcceptanceCriterion"
          },
          "minItems": 1,
          "title": "Criteria",
          "type": "array"
        }
      },
      "required": [
        "criteria"
      ],
      "title": "AcceptanceCriteria",
      "type": "object"
    },
    "AcceptanceCriterion": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Path"
        },
        "id": {
          "minLength": 1,
          "pattern": "^[A-Z]+-\\d{2,}$",
          "title": "Id",
          "type": "string"
        },
        "satisfied_by_steps": {
          "items": {
            "type": "integer"
          },
          "title": "Satisfied By Steps",
          "type": "array"
        },
        "verification_step": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verification Step"
        }
      },
      "required": [
        "id",
        "description"
      ],
      "title": "AcceptanceCriterion",
      "type": "object"
    },
    "CriticalFiles": {
      "additionalProperties": false,
      "properties": {
        "primary_files": {
          "items": {
            "$ref": "#/$defs/CriticalPrimaryFile"
          },
          "minItems": 1,
          "title": "Primary Files",
          "type": "array"
        },
        "reference_files": {
          "items": {
            "$ref": "#/$defs/ReferenceFile"
          },
          "title": "Reference Files",
          "type": "array"
        }
      },
      "required": [
        "primary_files"
      ],
      "title": "CriticalFiles",
      "type": "object"
    },
    "CriticalPrimaryFile": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "create",
            "modify",
            "delete"
          ],
          "title": "Action",
          "type": "string"
        },
        "estimated_changes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Changes"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action"
      ],
      "title": "CriticalPrimaryFile",
      "type": "object"
    },
    "DependencyInjection": {
      "additionalProperties": false,
      "properties": {
        "forbidden_patterns": {
          "items": {
            "enum": [
              "global-singleton",
              "module-level-mutable-state",
              "import-time-side-effects",
              "subprocess-time-random",
              "env-var-direct-read",
              "unknown"
            ],
            "type": "string"
          },
          "title": "Forbidden Patterns",
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "maxLength": 2000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "preferred_patterns": {
          "items": {
            "enum": [
              "constructor",
              "parameter",
              "interface",
              "service-locator",
              "ambient-context",
              "unknown"
            ],
            "type": "string"
          },
          "title": "Preferred Patterns",
          "type": "array"
        },
        "required_for_testability": {
          "title": "Required For Testability",
          "type": "boolean"
        }
      },
      "required": [
        "required_for_testability"
      ],
      "title": "DependencyInjection",
      "type": "object"
    },
    "DesignConstraints": {
      "additionalProperties": false,
      "properties": {
        "architecture_style": {
          "anyOf": [
            {
              "enum": [
                "monolith",
                "modular-monolith",
                "microservice",
                "library",
                "cli",
                "spa",
                "mobile",
                "serverless",
                "embedded",
                "unknown"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Architecture Style"
        },
        "invariants": {
          "items": {
            "type": "string"
          },
          "title": "Invariants",
          "type": "array"
        },
        "text": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "DesignConstraints",
      "type": "object"
    },
    "DesignSection": {
      "additionalProperties": false,
      "properties": {
        "acceptance_criteria": {
          "anyOf": [
            {
              "$ref": "#/$defs/AcceptanceCriteria"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "constraints": {
          "anyOf": [
            {
              "$ref": "#/$defs/DesignConstraints"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dependency_injection": {
          "anyOf": [
            {
              "$ref": "#/$defs/DependencyInjection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "drift_detection": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftDetection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "non_goals": {
          "anyOf": [
            {
              "$ref": "#/$defs/NonGoals"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "outcome": {
          "anyOf": [
            {
              "maxLength": 500,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outcome"
        },
        "planning_profile": {
          "anyOf": [
            {
              "enum": [
                "strict",
                "balanced",
                "minimal"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Planning Profile"
        },
        "refactor_strategy": {
          "anyOf": [
            {
              "$ref": "#/$defs/RefactorStrategy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "testability": {
          "anyOf": [
            {
              "$ref": "#/$defs/Testability"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "DesignSection",
      "type": "object"
    },
    "DriftDetection": {
      "additionalProperties": false,
      "properties": {
        "expected_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Expected Outputs",
          "type": "array"
        },
        "guard_commands": {
          "items": {
            "type": "string"
          },
          "title": "Guard Commands",
          "type": "array"
        },
        "on_drift_action": {
          "anyOf": [
            {
              "enum": [
                "fail-verify",
                "log-only",
                "open-issue",
                "ignore"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Drift Action"
        },
        "sources": {
          "items": {
            "enum": [
              "ruff",
              "mypy",
              "pytest",
              "make",
              "custom-script",
              "ci",
              "unknown"
            ],
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        }
      },
      "title": "DriftDetection",
      "type": "object"
    },
    "EditArea": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "paths": {
          "items": {
            "type": "string"
          },
          "title": "Paths",
          "type": "array"
        }
      },
      "title": "EditArea",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "A single evidence entry for a plan step.\n\nThe kind discriminator tells the executor how to verify the entry:\n\n- ``file``: a workspace file the executor can ``cat`` or stat\n- ``command_output``: a shell command the executor should run and\n  capture; the entry text is the command itself\n- ``test_name``: a single test id (e.g. ``tests/test_foo.py::test_x``)\n  the executor should run",
      "properties": {
        "kind": {
          "enum": [
            "file",
            "command_output",
            "test_name"
          ],
          "title": "Kind",
          "type": "string"
        },
        "note": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "ref": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "NonGoals": {
      "additionalProperties": false,
      "properties": {
        "items": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Items",
          "type": "array"
        }
      },
      "required": [
        "items"
      ],
      "title": "NonGoals",
      "type": "object"
    },
    "ParallelPlanItem": {
      "additionalProperties": false,
      "description": "A unit of parallelisable work with dependency tracking.",
      "properties": {
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "edit_area": {
          "$ref": "#/$defs/EditArea"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "description",
        "edit_area"
      ],
      "title": "ParallelPlanItem",
      "type": "object"
    },
    "PlanConstraints": {
      "additionalProperties": false,
      "properties": {
        "must_keep_working": {
          "items": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "title": "Must Keep Working",
          "type": "array"
        },
        "must_not_break": {
          "items": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "title": "Must Not Break",
          "type": "array"
        },
        "performance_budget": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Performance Budget"
        },
        "security_posture": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Security Posture"
        }
      },
      "title": "PlanConstraints",
      "type": "object"
    },
    "PlanStep": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "depends_on": {
          "items": {
            "type": "integer"
          },
          "title": "Depends On",
          "type": "array"
        },
        "expected_evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Expected Evidence",
          "type": "array"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "number": {
          "minimum": 1,
          "title": "Number",
          "type": "integer"
        },
        "priority": {
          "anyOf": [
            {
              "enum": [
                "critical",
                "high",
                "medium",
                "low"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Priority"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        },
        "satisfies": {
          "items": {
            "type": "string"
          },
          "title": "Satisfies",
          "type": "array"
        },
        "step_type": {
          "$ref": "#/$defs/StepType",
          "default": "action"
        },
        "targets": {
          "items": {
            "$ref": "#/$defs/StepTarget"
          },
          "title": "Targets",
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "verify_command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verify Command"
        }
      },
      "required": [
        "number",
        "title",
        "content"
      ],
      "title": "PlanStep",
      "type": "object"
    },
    "RefactorStrategy": {
      "additionalProperties": false,
      "properties": {
        "allow_temporary_hacks": {
          "default": false,
          "title": "Allow Temporary Hacks",
          "type": "boolean"
        },
        "approach": {
          "enum": [
            "greenfield",
            "incremental",
            "strangler",
            "branch-by-abstraction",
            "rebuild-in-parallel",
            "no-refactor"
