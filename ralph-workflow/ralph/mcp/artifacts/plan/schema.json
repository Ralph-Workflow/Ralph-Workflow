    "StepTarget": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "create",
            "modify",
            "delete",
            "read",
            "reference"
          ],
          "title": "Action",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path",
        "action"
      ],
      "title": "StepTarget",
      "type": "object"
    },
    "StepType": {
      "description": "Closed set of valid step kinds.\n\n- ``FILE_CHANGE``: the step creates, modifies, or deletes one or more\n  source files. The model validator requires at least one ``targets``\n  entry.\n- ``ACTION``: a non-mutating executor action (a command or a tool\n  call). No target/handle binding.\n- ``RESEARCH``: an exploratory step that may not produce a code\n  change. No target/handle binding.\n- ``VERIFY``: a pure-verification step (e.g. ``run ruff``, ``run\n  pytest``) with no file changes. The model validator requires\n  either ``verify_command`` or ``location``.",
      "enum": [
        "file_change",
        "action",
        "research",
        "verify"
      ],
      "title": "StepType",
      "type": "string"
    },
    "Summary": {
      "additionalProperties": false,
      "properties": {
        "context": {
          "default": "",
          "maxLength": 2000,
          "title": "Context",
          "type": "string"
        },
        "coverage_areas": {
          "items": {
            "enum": [
              "bugfix",
              "feature",
              "refactor",
              "test",
              "docs",
              "infra",
              "security",
              "performance",
              "migration",
              "release"
            ],
            "type": "string"
          },
          "title": "Coverage Areas",
          "type": "array"
        },
        "intent": {
          "default": "",
          "maxLength": 200,
          "title": "Intent",
          "type": "string"
        },
        "intent_verb": {
          "default": "",
          "title": "Intent Verb",
          "type": "string"
        },
        "scope_items": {
          "items": {
            "$ref": "#/$defs/ScopeItem"
          },
          "minItems": 3,
          "title": "Scope Items",
          "type": "array"
        }
      },
      "required": [
        "scope_items"
      ],
      "title": "Summary",
      "type": "object"
    },
    "Testability": {
      "additionalProperties": false,
      "properties": {
        "clock_injection_required": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clock Injection Required"
        },
        "forbidden_in_tests": {
          "items": {
            "enum": [
              "time.sleep",
              "subprocess.run-no-timeout",
              "real-file-IO",
              "real-network",
              "global-mutation",
              "monkeypatch-of-prod",
              "unknown"
            ],
            "type": "string"
          },
          "title": "Forbidden In Tests",
          "type": "array"
        },
        "max_unit_test_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 60,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Unit Test Seconds"
        },
        "must_be_black_box": {
          "title": "Must Be Black Box",
          "type": "boolean"
        },
        "required_test_layers": {
          "items": {
            "enum": [
              "unit",
              "integration",
              "subprocess_e2e",
              "property",
              "snapshot",
              "contract",
              "unknown"
            ],
            "type": "string"
          },
          "title": "Required Test Layers",
          "type": "array"
        }
      },
      "required": [
        "must_be_black_box"
      ],
      "title": "Testability",
      "type": "object"
    },
    "VerificationStep": {
      "additionalProperties": false,
      "properties": {
        "cwd": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cwd"
        },
        "expected_outcome": {
          "minLength": 1,
          "title": "Expected Outcome",
          "type": "string"
        },
        "method": {
          "minLength": 1,
          "title": "Method",
          "type": "string"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 3600,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Seconds"
        }
      },
      "required": [
        "method",
        "expected_outcome"
      ],
      "title": "VerificationStep",
      "type": "object"
    },
    "WorkUnit": {
      "description": "Single planning work unit declaration.",
      "properties": {
        "allowed_directories": {
          "items": {
