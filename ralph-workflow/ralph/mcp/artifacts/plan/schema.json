          "title": "Approach",
          "type": "string"
        },
        "dead_code_policy": {
          "default": "delete-immediately",
          "enum": [
            "delete-immediately",
            "delete-after-feature",
            "keep-for-trace",
            "unknown"
          ],
          "title": "Dead Code Policy",
          "type": "string"
        },
        "preserve_public_api": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preserve Public Api"
        }
      },
      "required": [
        "approach"
      ],
      "title": "RefactorStrategy",
      "type": "object"
    },
    "ReferenceFile": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "purpose": {
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        }
      },
      "required": [
        "path",
        "purpose"
      ],
      "title": "ReferenceFile",
      "type": "object"
    },
    "RiskMitigation": {
      "additionalProperties": false,
      "properties": {
        "mitigation": {
          "minLength": 1,
          "title": "Mitigation",
          "type": "string"
        },
        "risk": {
          "minLength": 1,
          "title": "Risk",
          "type": "string"
        },
        "severity": {
          "anyOf": [
            {
              "enum": [
                "low",
                "medium",
                "high",
