{#
  render_payload_section: Use for PRIMARY context that may need to be inlined
  (e.g. LATEST_ARTIFACT, ISSUES, FIX_RESULT, DIFF). Inlines content when path
  is absent; uses a file reference when path is present.
#}
{% macro render_payload_section(label, content, path) -%}
{{ label }}:
{% if path %}
Read the complete {{ label|lower }} from file at `{{ path }}` before continuing.
This file is the authoritative source for {{ label|lower }} in this prompt.
Do not ask the user to paste it again, and do not claim the {{ label|lower }} is missing.
{% else %}
{{ content }}
{% endif %}
{%- endmacro %}

{#
  render_payload_path: Use for SECONDARY context (e.g. PROMPT, PLAN in analysis
  phases) that must ALWAYS be a file reference — never inlined. Raises a
  TemplateRenderingError when path is empty to catch misconfiguration early.
#}
{% macro render_payload_path(label, path) -%}
{% if not path %}{{ raise_error("render_payload_path: path must not be empty for label=" ~ label) }}{% endif %}
{{ label }}:
Read the complete {{ label|lower }} from file at `{{ path }}` before continuing.
This file is the authoritative source for {{ label|lower }} in this prompt.
Do not ask the user to paste it again, and do not claim the {{ label|lower }} is missing.
{%- endmacro %}
